# Frontend (Vite) environment. Copy to .env for local overrides.
# Vite only exposes vars prefixed with VITE_ to the browser.

# Base URL of the AssistAI backend API. Defaults to http://localhost:8000 if unset.
# In production (e.g. Netlify), set this to your deployed backend URL.
VITE_API_BASE_URL=http://localhost:8000
