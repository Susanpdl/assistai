# Copy to .env and adjust for local development.
# These defaults match docker-compose.yml so the stack runs out of the box.

# Postgres (with the pgvector extension). The "+psycopg" picks the psycopg3 driver.
DATABASE_URL=postgresql+psycopg://assistai:assistai@localhost:5433/assistai

# Redis — cache + pub/sub backbone for the realtime layer.
REDIS_URL=redis://localhost:6379/0

# Dimension of stored embeddings. Pin this to your embedding model's output size
# (e.g. Voyage voyage-3 = 1024). Changing it later means re-embedding all content.
EMBEDDING_DIM=1024
# Which embedder to use. "local" = deterministic, offline (dev/tests, no API key).
# A real provider is wired in Phase 4.
EMBEDDING_BACKEND=local

# --- Content ingestion (Phase 3) ---
# Object storage for uploaded course files. "local" writes under STORAGE_DIR; this is the
# seam where an "s3" backend slots in for deployment.
STORAGE_BACKEND=local
STORAGE_DIR=./storage
MAX_UPLOAD_MB=20
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,pptx,txt,md
# Redis list the ingestion worker pulls document ids from.
INGEST_QUEUE_KEY=assistai:ingest
# Chunking (~500 tokens / ~50 overlap, approximated in characters).
CHUNK_CHARS=2000
CHUNK_OVERLAP_CHARS=200

# Comma-separated origins allowed to call the API from the browser (the Vite dev server).
CORS_ORIGINS=http://localhost:5173

# --- URLs ---
# Backend base URL (magic links point here, at /auth/verify).
API_BASE_URL=http://localhost:8000
# Where users land after a successful login.
FRONTEND_URL=http://localhost:5173

# --- Auth: magic link + sessions ---
TOKEN_TTL_MINUTES=15
SESSION_TTL_DAYS=14
SESSION_COOKIE_NAME=assistai_session
# Set true only when served over HTTPS.
SESSION_COOKIE_SECURE=false
# Emails that become `instructor` on first login (comma-separated). Everyone else is a student.
INSTRUCTOR_EMAILS=
# Rate limit for POST /auth/request (per email and per IP).
AUTH_REQUEST_MAX_PER_WINDOW=5
AUTH_REQUEST_WINDOW_MINUTES=15

# --- Email provider ---
# "console" logs the magic link to stdout (dev). "resend" sends real email.
EMAIL_BACKEND=console
EMAIL_FROM=AssistAI <login@assistai.local>
RESEND_API_KEY=
